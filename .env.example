# Get a key at https://build.nvidia.com (free tier available)
NVIDIA_API_KEY=nvapi-...

# Primary coding model — must support tool calling. Run `pnpm verify` to
# list available models and confirm tool-call support before settling on one.
NVIDIA_MODEL=z-ai/glm-5.2

# Cheap/fast model for lightweight tasks (inline edit, titles, etc.)
NVIDIA_FAST_MODEL=meta/llama-3.1-8b-instruct

# Embedding model for codebase indexing (Phase 5)
NVIDIA_EMBED_MODEL=nvidia/nv-embedcode-7b-v1
