{
  "name": "wright-extension",
  "displayName": "Wright",
  "description": "A Cursor-like AI coding agent powered by NVIDIA NIM",
  "version": "0.1.0",
  "publisher": "wright-dev",
  "license": "MIT",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "agent",
    "nvidia",
    "nim",
    "copilot",
    "chat"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Youngtech303/Wright.git",
    "directory": "apps/extension"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "wright",
          "title": "Wright",
          "icon": "media/wright.svg"
        }
      ]
    },
    "views": {
      "wright": [
        {
          "type": "webview",
          "id": "wright.chat",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "wright.newChat",
        "title": "Wright: New Chat",
        "icon": "$(add)"
      },
      {
        "command": "wright.focusChat",
        "title": "Wright: Open Chat"
      },
      {
        "command": "wright.rebuildIndex",
        "title": "Wright: Rebuild Codebase Index"
      },
      {
        "command": "wright.inlineEdit",
        "title": "Wright: Inline Edit (describe a change to the selection)"
      },
      {
        "command": "wright.generateCommitMessage",
        "title": "Wright: Generate Commit Message",
        "icon": "$(sparkle)"
      },
      {
        "command": "wright.addSelectionToChat",
        "title": "Add Selection to Chat"
      },
      {
        "command": "wright.explainSelection",
        "title": "Explain"
      },
      {
        "command": "wright.reviewSelection",
        "title": "Review"
      }
    ],
    "keybindings": [
      {
        "command": "wright.inlineEdit",
        "key": "ctrl+alt+k",
        "mac": "ctrl+cmd+k",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "wright.newChat",
          "when": "view == wright.chat",
          "group": "navigation"
        }
      ],
      "scm/title": [
        {
          "command": "wright.generateCommitMessage",
          "when": "scmProvider == git",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "wright.addSelectionToChat",
          "when": "editorHasSelection",
          "group": "0_wright@1"
        },
        {
          "command": "wright.inlineEdit",
          "when": "editorTextFocus",
          "group": "0_wright@2"
        },
        {
          "command": "wright.explainSelection",
          "when": "editorHasSelection",
          "group": "0_wright@3"
        },
        {
          "command": "wright.reviewSelection",
          "when": "editorHasSelection",
          "group": "0_wright@4"
        }
      ]
    },
    "configuration": {
      "title": "Wright",
      "properties": {
        "wright.nvidia.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "NVIDIA NIM API key from [build.nvidia.com](https://build.nvidia.com). If empty, Wright falls back to the `NVIDIA_API_KEY` env var, then to a `.env` file at the workspace root."
        },
        "wright.model.chat": {
          "type": "string",
          "default": "z-ai/glm-5.2",
          "description": "Primary model for chat and (later) the agent. Must support tool calling."
        },
        "wright.model.fast": {
          "type": "string",
          "default": "meta/llama-3.1-8b-instruct",
          "description": "Cheap/fast model for lightweight tasks."
        },
        "wright.model.embed": {
          "type": "string",
          "default": "nvidia/nv-embedcode-7b-v1",
          "description": "Embedding model for codebase indexing (semantic search)."
        },
        "wright.model.vision": {
          "type": "string",
          "default": "meta/llama-4-maverick-17b-128e-instruct",
          "description": "Multimodal model used when the chat message includes an image. Must accept image input."
        },
        "wright.webSearch.provider": {
          "type": "string",
          "enum": [
            "duckduckgo",
            "tavily",
            "brave"
          ],
          "default": "duckduckgo",
          "enumDescriptions": [
            "Keyless, but only covers well-known topics (instant-answer API)",
            "Full web search (requires an API key from tavily.com)",
            "Full web search (requires a Brave Search API key)"
          ],
          "description": "Backend for the agent's web_search tool."
        },
        "wright.webSearch.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "API key for the chosen web search provider (Tavily or Brave). Not needed for DuckDuckGo."
        },
        "wright.approvalMode": {
          "type": "string",
          "enum": [
            "manual",
            "auto-edit",
            "auto"
          ],
          "default": "auto-edit",
          "enumDescriptions": [
            "Every file edit and shell command asks for approval",
            "File edits run silently; shell commands ask (allowlisted ones run)",
            "Everything runs silently except deny-listed commands and protected paths"
          ],
          "description": "How much Wright's agent can do without asking."
        },
        "wright.pricing.inputPer1M": {
          "type": "number",
          "default": 0,
          "description": "USD per 1M input tokens, for the session cost estimate (0 = show token counts only)."
        },
        "wright.pricing.outputPer1M": {
          "type": "number",
          "default": 0,
          "description": "USD per 1M output tokens, for the session cost estimate (0 = show token counts only)."
        },
        "wright.autocomplete.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Ghost-text tab completions via a local Ollama FIM model (never uses NVIDIA quota). Silently inactive if Ollama isn't running."
        },
        "wright.autocomplete.model": {
          "type": "string",
          "default": "qwen-coder-7b:latest",
          "description": "Ollama model for autocomplete. Must support fill-in-middle (the 'insert' capability)."
        },
        "wright.autocomplete.ollamaUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Base URL of the local Ollama server."
        },
        "wright.models.list": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "z-ai/glm-5.2",
            "mistralai/mistral-large-3-675b-instruct-2512",
            "deepseek-ai/deepseek-v4-pro",
            "moonshotai/kimi-k2.6",
            "nvidia/nemotron-3-super-120b-a12b",
            "qwen/qwen3.5-122b-a10b",
            "minimaxai/minimax-m3",
            "meta/llama-3.3-70b-instruct",
            "meta/llama-3.1-8b-instruct"
          ],
          "markdownDescription": "Models shown in the chat picker. Add or remove any NVIDIA NIM model id (must support tool calling for agent work — check with `pnpm verify -- <id>`). \"auto\" is always included."
        },
        "wright.defaultMode": {
          "type": "string",
          "enum": [
            "agent",
            "plan",
            "debug",
            "ask",
            "multi"
          ],
          "default": "agent",
          "description": "Mode the chat starts in."
        },
        "wright.edits.autoKeep": {
          "type": "boolean",
          "default": false,
          "description": "Automatically keep all agent edits after each turn (skip the manual Keep all). Files remain revertible only until the turn ends."
        },
        "wright.mcp.servers": {
          "type": "object",
          "default": {},
          "markdownDescription": "MCP (Model Context Protocol) servers whose tools the agent can use. Example: `{\"github\": {\"command\": \"npx\", \"args\": [\"-y\", \"@modelcontextprotocol/server-github\"]}}`. MCP tools require approval except in auto mode.",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "command": {
                "type": "string"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "env": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            },
            "required": [
              "command"
            ]
          }
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "vscode:prepublish": "pnpm --filter @wright/core build && node esbuild.mjs",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.0",
    "@wright/core": "workspace:*",
    "esbuild": "^0.28.0",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.7.0"
  }
}
