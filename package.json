{
  "name": "wright",
  "private": true,
  "version": "0.1.0",
  "description": "A Cursor-like AI IDE powered by NVIDIA NIM",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "verify": "pnpm --filter @wright/core build && pnpm --filter @wright/cli verify",
    "chat": "pnpm --filter @wright/core build && pnpm --filter @wright/cli chat",
    "agent": "pnpm --filter @wright/core build && pnpm --filter @wright/cli agent",
    "index": "pnpm --filter @wright/core build && pnpm --filter @wright/cli index",
    "package": "pnpm --filter wright-extension package"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.20.0"
}
